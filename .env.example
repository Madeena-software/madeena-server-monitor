# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email recipients (comma-separated)
ALERT_FROM=your-email@gmail.com
ALERT_TO=admin@example.com,ops@example.com

# Alert thresholds (percentage 0–100)
CPU_THRESHOLD=95
RAM_THRESHOLD=90
ROOT_DISK_THRESHOLD=90

# Temperature threshold in Celsius for the cumulative OR-logic alert
TEMP_THRESHOLD=85

# Number of consecutive high-CPU checks before an alert is sent
CPU_CONSECUTIVE_CHECKS=3

# How often to check CPU/RAM (e.g. 1m, 30s)
CHECK_INTERVAL=1m

# How often to check disk space (e.g. 15m, 1h)
DISK_INTERVAL=15m

# Minimum time between repeated alerts for the same issue (e.g. 3h)
ALERT_COOLDOWN=3h

# Hour of the day (0–23) to send the daily heartbeat summary
HEARTBEAT_HOUR=8

# Extra disk mount points to monitor beyond root (comma-separated)
# DATA_PARTITIONS=/mnt/data,/mnt/backup

# Friendly server name used in email subjects
SERVER_NAME=madeena-server

# TCP port for the live web dashboard (default: 8080)
WEB_PORT=8080
